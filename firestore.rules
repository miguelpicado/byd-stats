rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // BYD Vehicles - documento principal y subcolecciones
    // TODO: Añadir reglas de auth para producción
    match /bydVehicles/{vehicleId} {
      allow read, write: if true;

      // Trips subcolección
      match /trips/{tripId} {
        allow read, write: if true;
        
        match /points/{pointId} {
          allow read, write: if true;
        }
      }

      // Charges subcolección
      match /charges/{chargeId} {
        allow read, write: if true;
      }

      // Charging Sessions subcolección
      match /chargingSessions/{sessionId} {
        allow read, write: if true;
      }
    }

    // Legacy collections
    match /trips/{tripId} {
      allow read, write: if true;
      
      match /points/{pointId} {
        allow read, write: if true;
      }
    }

    match /vehicles/{vehicleId} {
      allow read, write: if true;
    }

    match /chargeSessions/{sessionId} {
      allow read, write: if true;
    }

    match /chargeNotifications/{notificationId} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
