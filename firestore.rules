rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================================================
    // BYD VEHICLES
    // Solo el propietario del vehículo puede leer/escribir su documento.
    // ==========================================================================
    match /bydVehicles/{vehicleId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;

      // ------------------------------------------------------------------
      // Credenciales y sesiones — BLOQUEADO desde el cliente.
      // Solo accesible mediante el Admin SDK (Cloud Functions).
      // ------------------------------------------------------------------
      match /private/{doc} {
        allow read, write: if false;
      }

      // ------------------------------------------------------------------
      // Trips — solo el propietario del vehículo
      // ------------------------------------------------------------------
      match /trips/{tripId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/bydVehicles/$(vehicleId)).data.userId == request.auth.uid;

        match /points/{pointId} {
          allow read, write: if request.auth != null
            && get(/databases/$(database)/documents/bydVehicles/$(vehicleId)).data.userId == request.auth.uid;
        }
      }

      // ------------------------------------------------------------------
      // Charges — solo el propietario del vehículo
      // ------------------------------------------------------------------
      match /charges/{chargeId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/bydVehicles/$(vehicleId)).data.userId == request.auth.uid;
      }

      // ------------------------------------------------------------------
      // Charging Sessions — solo el propietario del vehículo
      // ------------------------------------------------------------------
      match /chargingSessions/{sessionId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/bydVehicles/$(vehicleId)).data.userId == request.auth.uid;
      }

      // ------------------------------------------------------------------
      // Auto Charges — sesiones registradas automáticamente por el backend
      // Solo el propietario del vehículo puede leer/escribir
      // ------------------------------------------------------------------
      match /autoCharges/{chargeId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/bydVehicles/$(vehicleId)).data.userId == request.auth.uid;
      }
    }

    // ==========================================================================
    // USERS
    // Cada usuario solo puede leer/escribir su propio documento.
    // ==========================================================================
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ==========================================================================
    // LEGACY COLLECTIONS — fully blocked
    // Deprecated collections. All data lives in bydVehicles/{vin}/* now.
    // No client should read or write here in production.
    // ==========================================================================
    match /trips/{tripId} {
      allow read, write: if false;
      match /points/{pointId} {
        allow read, write: if false;
      }
    }

    match /vehicles/{vehicleId} {
      allow read, write: if false;
    }

    match /chargeSessions/{sessionId} {
      allow read, write: if false;
    }

    match /chargeNotifications/{notificationId} {
      allow read, write: if false;
    }
  }
}
