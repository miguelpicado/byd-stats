# BYD-Stats Cloud Functions Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to git!

# Smartcar Webhook Authentication (get from Smartcar Dashboard > Webhooks)
SMARTCAR_AMT=your-smartcar-amt-secret

# Smartcar OAuth (get from Smartcar Dashboard)
SMARTCAR_CLIENT_ID=your-smartcar-client-id
SMARTCAR_CLIENT_SECRET=your-smartcar-client-secret
SMARTCAR_REDIRECT_URI=https://javascript-sdk.smartcar.com/v2/redirect?app_origin=http://localhost:5173

# Smartcar Webhook ID (get from Smartcar Dashboard > Webhooks)
# This is required for automatic webhook subscription when vehicles are connected
SMARTCAR_WEBHOOK_ID=your-webhook-id-uuid

# Admin API Key for /diag endpoint (generate a secure random string)
# Example: openssl rand -hex 32
ADMIN_API_KEY=your-secure-admin-api-key

# Token Encryption Key for storing Smartcar tokens securely (32 bytes hex = 64 chars)
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your-64-character-hex-encryption-key

# Google Maps API Key for Snap to Roads (optional)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
