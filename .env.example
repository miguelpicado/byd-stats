# BYD-Stats Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to git!

# Google OAuth (get from Google Cloud Console)
VITE_GOOGLE_WEB_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Firebase Configuration (get from Firebase Console > Project Settings)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Smartcar Configuration (get from Smartcar Dashboard)
VITE_SMARTCAR_CLIENT_ID=your-smartcar-client-id
VITE_SMARTCAR_REDIRECT_URI=https://javascript-sdk.smartcar.com/v2/redirect?app_origin=http://localhost:5173
