# BYD MQTT Listener Configuration
# Copy this to .env and fill in your values

# BYD User credentials (obtained after bydConnect)
# These are stored in Firestore: bydVehicles/{vin}/private/credentials
BYD_USER_ID=your_user_id
BYD_SIGN_TOKEN=your_sign_token
BYD_ENCRY_TOKEN=your_encry_token

# MQTT Broker (usually obtained from getEmqBrokerIp, defaults work for EU)
BYD_MQTT_HOST=emqoversea-eu.byd.auto
BYD_MQTT_PORT=8883

# Device fingerprint (same as used in login, default is fine)
BYD_IMEI_MD5=00000000000000000000000000000000

# Firebase webhook endpoint
FIREBASE_WEBHOOK_URL=https://europe-west1-REDACTED_FIREBASE_PROJECT_ID.cloudfunctions.net/bydMqttWebhook

# Secret for webhook authentication (generate a random string)
WEBHOOK_SECRET=your_random_secret_here
